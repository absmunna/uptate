// PaikarMart — Production Prisma Schema
// Optimized for PostgreSQL (Supabase / Render)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  guest
  buyer
  seller
  wholesale
  factory
  rural
  nearby_shop
  rider
  service_provider
  digital_seller
  moderator
  admin
  super_admin
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum SellerType {
  retail
  wholesale
  service
  factory
}

enum PayoutMethod {
  bkash
  nagad
  rocket
  bank
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  phone            String    @unique
  email            String?   @unique
  passwordHash     String
  fullName         String
  avatarUrl        String?
  role             UserRole  @default(buyer)
  isVerified       Boolean   @default(false)
  isActive         Boolean   @default(true)

  // Address & identity (BD compliance: merchant accountability)
  address          String?
  district         String?
  upazila          String?
  postCode         String?

  // Seller-specific (populated when role = seller/wholesale/factory)
  shopName         String?
  sellerType       SellerType?
  nidNumber        String?    // National ID (masked in responses)
  tradeLicenseNo   String?
  businessAddress  String?
  vatRegNo         String?    // VAT registration number

  // Payout
  payoutMethod     PayoutMethod?
  payoutAccount    String?   // Mobile number or bank account

  // PK Coin wallet
  pkCoinBalance    Int       @default(0)

  // Relations
  products         Product[]
  orders           Order[]   @relation("BuyerOrders")
  sellerOrders     Order[]   @relation("SellerOrders")
  posts            Post[]
  cartItems        CartItem[]
  notifications    Notification[]
  demands          Demand[]
  reviews          Review[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([role])
  @@index([phone])
}

// ─── PRODUCT ─────────────────────────────────────────────────────────────────

model Product {
  id               String    @id @default(uuid())
  title            String
  description      String    @db.Text
  price            Decimal   @db.Decimal(12, 2)
  originalPrice    Decimal?  @db.Decimal(12, 2)
  currency         String    @default("BDT")

  // BD compliance: price transparency
  vatRate          Decimal   @default(0) @db.Decimal(5, 2)  // e.g., 15.00 for 15% VAT
  shippingFeeInside  Decimal @default(0) @db.Decimal(10, 2) // Inside major zones (Dhaka)
  shippingFeeOutside Decimal @default(0) @db.Decimal(10, 2) // Outside major zones
  deliveryDaysInside  Int    @default(3)  // Max delivery days inside Dhaka
  deliveryDaysOutside Int    @default(7)  // Max delivery days outside Dhaka

  images           String[]  @default([])
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id])
  tags             String[]  @default([])

  stock            Int       @default(0)
  minOrderQty      Int       @default(1)
  unit             String    @default("pcs") // pcs, kg, dozen, etc.

  type             String    @default("retail") // retail, wholesale, b2b
  isPKStore        Boolean   @default(false)
  isActive         Boolean   @default(true)

  // Location (for nearby discovery)
  district         String?
  upazila          String?

  sellerId         String
  seller           User      @relation(fields: [sellerId], references: [id])

  orderItems       OrderItem[]
  cartItems        CartItem[]
  reviews          Review[]
  postProducts     PostProduct[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([sellerId])
  @@index([categoryId])
  @@index([type])
  @@index([isActive])
}

// ─── CATEGORY ─────────────────────────────────────────────────────────────────

model Category {
  id           String    @id @default(uuid())
  name         String    @unique
  nameBn       String?
  slug         String    @unique
  icon         String?
  productCount Int       @default(0)
  products     Product[]

  createdAt    DateTime  @default(now())
}

// ─── ORDER ───────────────────────────────────────────────────────────────────

model Order {
  id               String      @id @default(uuid())
  orderNo          String      @unique @default(cuid())

  buyerId          String
  buyer            User        @relation("BuyerOrders", fields: [buyerId], references: [id])

  sellerId         String
  seller           User        @relation("SellerOrders", fields: [sellerId], references: [id])

  items            OrderItem[]
  status           OrderStatus @default(pending)

  // BD compliance: full price breakdown in BDT
  subtotal         Decimal     @db.Decimal(12, 2)
  vatAmount        Decimal     @default(0) @db.Decimal(10, 2)
  shippingFee      Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal     @default(0) @db.Decimal(10, 2)
  total            Decimal     @db.Decimal(12, 2)
  currency         String      @default("BDT")

  // BD compliance: delivery commitment
  deliveryAddress  String
  deliveryDistrict String
  expectedDelivery DateTime?
  maxDeliveryDays  Int         @default(7)

  // Legal consent
  termsAcceptedAt  DateTime?   // Timestamp when buyer accepted T&C at checkout

  paymentMethod    String?     // bkash, nagad, cod, etc.
  paymentRef       String?

  notes            String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  title       String   // snapshot at time of purchase
  price       Decimal  @db.Decimal(12, 2)
  vatAmount   Decimal  @default(0) @db.Decimal(10, 2)
  qty         Int      @default(1)
  unit        String   @default("pcs")

  @@index([orderId])
  @@index([productId])
}

// ─── CART ─────────────────────────────────────────────────────────────────────

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  qty       Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── SOCIAL FEED ─────────────────────────────────────────────────────────────

model Post {
  id           String        @id @default(uuid())
  authorId     String
  author       User          @relation(fields: [authorId], references: [id])
  content      String        @db.Text
  imageUrl     String?
  mediaUrl     String?
  isPromoted   Boolean       @default(false)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)
  products     PostProduct[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([authorId])
  @@index([isPromoted])
  @@index([createdAt])
}

model PostProduct {
  postId    String
  post      Post    @relation(fields: [postId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@id([postId, productId])
}

// ─── DEMAND / RFQ ─────────────────────────────────────────────────────────────

model Demand {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  description String?  @db.Text
  budget      Decimal? @db.Decimal(12, 2)
  currency    String   @default("BDT")
  categoryId  String?
  location    String?
  district    String?
  urgency     String   @default("normal")
  status      String   @default("open")
  matchCount  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([status])
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1–5
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}
