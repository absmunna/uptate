// PaikarMart — Production Prisma Schema
// Optimized for PostgreSQL (Supabase / Render)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ROLES & PERMISSIONS (Constitution Rule 2/4) ──────────────────────────

model Role {
  id          String             @id @default(uuid())
  name        String             @unique
  permissions Permission[]
  userRoles   UserRoleRelation[]
  createdAt   DateTime           @default(now())
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[]
}

model UserRoleRelation {
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  guest
  buyer
  seller
  wholesale
  factory
  rural
  nearby_shop
  rider
  service_provider
  digital_seller
  moderator
  admin
  super_admin
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum SellerType {
  retail
  wholesale
  service
  factory
}

enum PayoutMethod {
  bkash
  nagad
  rocket
  bank
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  phone            String    @unique
  email            String?   @unique
  passwordHash     String
  fullName         String
  avatarUrl        String?
  role             UserRole  @default(buyer)
  isVerified       Boolean   @default(false)
  isActive         Boolean   @default(true)

  // Address & identity (BD compliance: merchant accountability)
  address          String?
  district         String?
  upazila          String?
  postCode         String?

  // Seller-specific (populated when role = seller/wholesale/factory)
  shopName         String?
  sellerType       SellerType?
  nidNumber        String?    // National ID (masked in responses)
  tradeLicenseNo   String?
  businessAddress  String?
  vatRegNo         String?    // VAT registration number

  // Payout
  payoutMethod     PayoutMethod?
  payoutAccount    String?   // Mobile number or bank account

  // PK Coin wallet
  pkCoinBalance    Int       @default(0)

  // Relations
  products         Product[]
  orders           Order[]   @relation("BuyerOrders")
  sellerOrders     Order[]   @relation("SellerOrders")
  posts            Post[]
  contentItems     ContentItem[]
  cartItems        CartItem[]
  notifications    Notification[]
  demands          Demand[]
  reviews          Review[]
  complaints       Complaint[]
  wallets          Wallet[]
  followers        FollowRelationship[] @relation("Follower")
  contentComments  ContentComment[]
  contentReactions ContentReaction[]
  contentBookmarks ContentBookmark[]
  contentShares    ContentShare[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  sellerProfile    SellerProfile?
  userRoles        UserRoleRelation[]
  fileAssets       FileAsset[]

  @@index([role])
  @@index([phone])
}

// ─── SELLER PROFILE ──────────────────────────────────────────────────────────

model SellerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  storeName      String
  sellerType     String   @default("retail")
  nidNumber      String?
  tradeLicenseNo String?
  businessPhone  String?
  division       String?
  district       String?
  upazila        String?
  addressDetails String?
  verificationStatus String @default("pending")
  verificationBadge  String @default("bronze")
  moderatorNote      String?
  commissionRate     Float    @default(10.0)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model PlatformEventLog {
  id        String   @id @default(uuid())
  eventId   String   @unique
  type      String
  payload   Json
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model PlatformMetric {
  id        String   @id @default(uuid())
  key       String   // e.g., "event_throughput", "engagement_rate"
  value     Float
  timestamp DateTime @default(now())

  @@index([key, timestamp])
}

model GovernancePolicy {
  id        String   @id @default(uuid())
  key       String   @unique
  threshold Float
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model FlaggedContent {
  id              String      @id @default(uuid())
  contentItemId   String
  reason          String
  reporterId      String
  status          String      @default("pending") // pending, reviewed, resolved
  moderatorNote   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ViolationLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  severity  String
  createdAt DateTime @default(now())
}

model FollowRelationship {
  id           String    @id @default(uuid())
  followerId   String
  follower     User      @relation("Follower", fields: [followerId], references: [id])
  targetId     String    // Polymorphic ID
  targetType   String    // "USER" | "BUSINESS" | "CATEGORY"
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@unique([followerId, targetId, targetType])
  @@index([targetId, targetType])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("BDT")
  type      String   @default("main") // main, cashback, etc.
  
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Transaction {
  id        String   @id @default(uuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  amount    Decimal  @db.Decimal(12, 2)
  type      String   // credit, debit
  status    String   @default("completed")
  reference String?
  description String?

  createdAt DateTime @default(now())
}

// ─── SOCIAL EXTENSIONS ──────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  authorId  String
  
  createdAt DateTime @default(now())
}

model Story {
  id        String   @id @default(uuid())
  authorId  String
  mediaUrl  String
  mediaType String   @default("image") // image, video
  expiresAt DateTime
  
  createdAt DateTime @default(now())
}

// ─── COMPLIANCE ─────────────────────────────────────────────────────────────

model ProductCategoryConfig {
  id                 String  @id @default(uuid())
  categoryId         String? @unique
  isActive           Boolean @default(true)
  defaultCommission  Float   @default(0)
  paymentReleaseRule String?
  returnWindowDays   Int?
  requiresKyc        Boolean @default(true)
  
  createdAt   DateTime @default(now())
}

model Escrow {
  id             String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  amount         Decimal  @db.Decimal(12, 2)
  status         String   @default("held") // held, released, refunded
  releaseAt      DateTime?
  createdAt      DateTime @default(now())
}

model FileAsset {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  url         String   // S3 URL
  key         String   // S3 Key for deletion/management
  mimeType    String
  size        Int
  purpose     String   // product_image, doc_nid, doc_trade_license
  createdAt   DateTime @default(now())
}

model Complaint {
  id             String   @id @default(uuid())
  orderIdString  String?  // Using orderIdString to avoid conflict with relation if any
  orderId        String?
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  targetSellerId String?
  subject        String
  description    String   @db.Text
  status         String   @default("open")
  priority       String   @default("low")
  
  createdAt      DateTime @default(now())
  deletedAt      DateTime?
}

// ─── PRODUCT ─────────────────────────────────────────────────────────────────

model Product {
  id               String    @id @default(uuid())
  title            String
  description      String    @db.Text
  price            Decimal   @db.Decimal(12, 2)
  originalPrice    Decimal?  @db.Decimal(12, 2)
  currency         String    @default("BDT")

  // BD compliance: price transparency
  vatRate          Decimal   @default(0) @db.Decimal(5, 2)  // e.g., 15.00 for 15% VAT
  shippingFeeInside  Decimal @default(0) @db.Decimal(10, 2) // Inside major zones (Dhaka)
  shippingFeeOutside Decimal @default(0) @db.Decimal(10, 2) // Outside major zones
  deliveryDaysInside  Int    @default(3)  // Max delivery days inside Dhaka
  deliveryDaysOutside Int    @default(7)  // Max delivery days outside Dhaka

  images           String[]  @default([])
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id])
  tags             String[]  @default([])

  stock            Int       @default(0)
  minOrderQty      Int       @default(1)
  unit             String    @default("pcs") // pcs, kg, dozen, etc.

  type             String    @default("retail") // retail, wholesale, b2b
  isPKStore        Boolean   @default(false)
  isActive         Boolean   @default(true)

  // Location (for nearby discovery)
  district         String?
  upazila          String?

  sellerId         String
  seller           User      @relation(fields: [sellerId], references: [id])

  orderItems       OrderItem[]
  cartItems        CartItem[]
  reviews          Review[]
  postProducts     PostProduct[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([sellerId])
  @@index([categoryId])
  @@index([type])
  @@index([isActive])
}

// ─── CATEGORY ─────────────────────────────────────────────────────────────────

model Category {
  id           String    @id @default(uuid())
  name         String    @unique
  nameBn       String?
  slug         String    @unique
  icon         String?
  productCount Int       @default(0)
  products     Product[]

  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
}

// ─── ORDER ───────────────────────────────────────────────────────────────────

model Order {
  id               String      @id @default(uuid())
  orderNo          String      @unique @default(cuid())

  buyerId          String
  buyer            User        @relation("BuyerOrders", fields: [buyerId], references: [id])

  sellerId         String
  seller           User        @relation("SellerOrders", fields: [sellerId], references: [id])

  items            OrderItem[]
  status           OrderStatus @default(pending)

  // BD compliance: full price breakdown in BDT
  subtotal         Decimal     @db.Decimal(12, 2)
  vatAmount        Decimal     @default(0) @db.Decimal(10, 2)
  shippingFee      Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal     @default(0) @db.Decimal(10, 2)
  total            Decimal     @db.Decimal(12, 2)
  currency         String      @default("BDT")

  // BD compliance: delivery commitment
  deliveryAddress  String
  deliveryDistrict String
  expectedDelivery DateTime?
  maxDeliveryDays  Int         @default(7)

  // Legal consent
  termsAcceptedAt  DateTime?   // Timestamp when buyer accepted T&C at checkout

  paymentMethod    String?     // bkash, nagad, cod, etc.
  paymentRef       String?
  paymentStatus    String?     // pending, paid, holding_escrow
  disputeStatus    String?     // none, raised, resolved

  notes            String?     @db.Text
  escrow           Escrow?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  title       String   // snapshot at time of purchase
  price       Decimal  @db.Decimal(12, 2)
  vatAmount   Decimal  @default(0) @db.Decimal(10, 2)
  qty         Int      @default(1)
  unit        String   @default("pcs")

  @@index([orderId])
  @@index([productId])
}

// ─── CART ─────────────────────────────────────────────────────────────────────

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  qty       Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── SOCIAL FEED ─────────────────────────────────────────────────────────────

model Post {
  id           String        @id @default(uuid())
  authorId     String
  author       User          @relation(fields: [authorId], references: [id])
  content      String        @db.Text
  imageUrl     String?
  mediaUrl     String?
  isPromoted   Boolean       @default(false)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)
  products     PostProduct[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([authorId])
  @@index([isPromoted])
  @@index([createdAt])
}

model PostProduct {
  postId    String
  post      Post    @relation(fields: [postId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@id([postId, productId])
}

// ─── DEMAND / RFQ ─────────────────────────────────────────────────────────────

model Demand {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  description String?  @db.Text
  budget      Decimal? @db.Decimal(12, 2)
  currency    String   @default("BDT")
  categoryId  String?
  location    String?
  district    String?
  urgency     String   @default("normal")
  status      String   @default("open")
  matchCount  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([authorId])
  @@index([status])
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1–5
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model ContentItem {
  id           String            @id @default(uuid())
  authorId     String
  author       User              @relation(fields: [authorId], references: [id])
  contentType  String            // "PRODUCT" | "BUSINESS" | "SERVICE" | "ANNOUNCEMENT" | "OFFER"
  title        String
  content      String            @db.Text
  mediaUrl     String?
  isPromoted   Boolean           @default(false)
  visibility   String            @default("PUBLIC") // "PUBLIC" | "FOLLOWERS_ONLY" | "PRIVATE"
  metadata     Json              @default("{}") // Store type-specific attributes
  likeCount    Int               @default(0)
  commentCount Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  comments     ContentComment[]
  reactions    ContentReaction[]
  bookmarks    ContentBookmark[]
  shares       ContentShare[]
  analytics    ContentAnalytics?

  @@index([authorId])
  @@index([contentType])
  @@index([createdAt])
  @@index([visibility])
}

model ContentReaction {
  id            String          @id @default(uuid())
  contentItemId String
  contentItem   ContentItem     @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String          // "LIKE" | "LOVE" | "WOW"
  createdAt     DateTime        @default(now())
  deletedAt     DateTime?

  @@unique([contentItemId, userId])
  @@index([contentItemId])
  @@index([userId])
}

model ContentComment {
  id              String           @id @default(uuid())
  contentItemId   String
  contentItem     ContentItem      @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentCommentId String?
  parentComment   ContentComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         ContentComment[] @relation("CommentReplies")
  content         String           @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@index([contentItemId])
  @@index([userId])
  @@index([parentCommentId])
}

model ContentBookmark {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItemId String
  contentItem   ContentItem     @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  collectionName String         @default("Favorites") // e.g. "Wholesale deals", "PK store list"
  createdAt     DateTime        @default(now())
  deletedAt     DateTime?

  @@unique([userId, contentItemId])
  @@index([userId])
  @@index([contentItemId])
}

model ContentShare {
  id            String          @id @default(uuid())
  contentItemId String
  contentItem   ContentItem     @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform      String          @default("INTERNAL") // "INTERNAL" | "FACEBOOK" | "WHATSAPP" | "COPY_LINK"
  createdAt     DateTime        @default(now())

  @@index([contentItemId])
}

model ContentAnalytics {
  id              String      @id @default(uuid())
  contentItemId   String      @unique
  contentItem     ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  viewCount       Int         @default(0)   // Mapped to reach
  engagementRate  Float       @default(0.0) // engagement count / viewCount
  viralityIndex   Float       @default(0.0) // computed velocity index
  lastComputedAt  DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}


